{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' teams.microsoft.com *.teams.microsoft.com *.microsoft365.com *.office.com *.skype.com *.teams.microsoft.us"
        }
      ]
    }
  ]
}
